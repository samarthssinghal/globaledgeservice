---
interface Props {
  title: string;
  summary: string;
  details?: string;
  icon: string;
}
const { title, summary, details, icon } = Astro.props;
---

<div class="group h-full rounded-xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-lg">
  <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10 text-accent-dark transition-colors group-hover:bg-accent group-hover:text-white">
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
    </svg>
  </div>
  <h3 class="mt-5 text-lg font-semibold text-navy">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-muted">{summary}</p>
  {details && <p class="mt-3 text-sm leading-relaxed text-slate-500">{details}</p>}
</div>
