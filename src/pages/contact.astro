---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const embedUrl = `${site.contactFormUrl}?embedded=true`;
const contactItems = [
  { label: "Email", value: site.email, href: `mailto:${site.email}` },
  { label: "Phone", value: site.phone, href: site.phoneHref },
  { label: "Address", value: site.address },
  { label: "LinkedIn", value: "Connect with us", href: site.linkedin },
];
---

<BaseLayout title="Contact" description="Get in touch with Global Edge Enterprise about your hiring needs.">
  <!-- Header -->
  <section class="bg-navy py-16 text-white">
    <div class="container-px">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-light">Contact</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight">Let's start a conversation</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">
        Whether you're hiring or exploring your next role, we'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="container-px py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-navy">Reach us directly</h2>
        <dl class="mt-6 space-y-5">
          {
            contactItems.map((item) => (
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wider text-muted">{item.label}</dt>
                <dd class="mt-1 text-base text-navy">
                  {item.href ? (
                    <a
                      href={item.href}
                      target={item.href.startsWith("http") ? "_blank" : undefined}
                      rel={item.href.startsWith("http") ? "noopener" : undefined}
                      class="transition-colors hover:text-accent-dark"
                    >
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>
        <div class="mt-8 rounded-xl border border-slate-200 bg-slate-50 p-5 text-sm text-muted">
          Our team typically responds within one business day.
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-navy">Send us a message</h2>
        <p class="mt-2 text-sm text-muted">This form is powered by Google Forms.</p>
        <!-- TODO: replace contactFormUrl in src/data/site.ts with your real Google Form -->
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
          <iframe
            src={embedUrl}
            title="Contact form"
            loading="lazy"
            class="h-[800px] w-full"
          >Loading…</iframe>
        </div>
        <p class="mt-3 text-sm text-muted">
          Form not loading?
          <a href={site.contactFormUrl} target="_blank" rel="noopener" class="font-medium text-accent-dark hover:underline">
            Open it in a new tab
          </a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
