---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTA from "../components/CTA.astro";
import { services, differentiators, stats } from "../data/site";
---

<BaseLayout>
  <Hero />

  <!-- Stats band -->
  <section class="border-b border-slate-200 bg-slate-50">
    <div class="container-px grid grid-cols-2 gap-6 py-10 md:grid-cols-4">
      {
        stats.map((s) => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-navy">{s.value}</div>
            <div class="mt-1 text-sm text-muted">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Intro -->
  <section class="container-px py-16 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-accent-dark">Who we are</p>
    <h2 class="mx-auto mt-3 max-w-3xl text-3xl font-bold text-navy">
      Finding the right talent, made simple
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-muted">
      We pair deep industry knowledge with a people-first process to connect great companies and
      great professionals — for roles that matter, at the speed your business moves.
    </p>
  </section>

  <!-- Services -->
  <section class="bg-slate-50 py-16">
    <div class="container-px">
      <div class="mb-10 text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent-dark">What we do</p>
        <h2 class="mt-3 text-3xl font-bold text-navy">Our recruitment services</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => <ServiceCard title={s.title} summary={s.summary} icon={s.icon} />)}
      </div>
    </div>
  </section>

  <!-- Why choose us -->
  <section class="container-px py-16">
    <div class="mb-10 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-dark">Why choose us</p>
      <h2 class="mt-3 text-3xl font-bold text-navy">The Global Edge difference</h2>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        differentiators.map((d) => (
          <div class="text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-navy text-white">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={d.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-navy">{d.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{d.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CTA />
</BaseLayout>
