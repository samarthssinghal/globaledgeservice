---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import { stats, differentiators } from "../data/site";

const values = [
  {
    title: "Integrity",
    body: "We do what we say, communicate honestly, and protect the trust placed in us by candidates and clients alike.",
  },
  {
    title: "Partnership",
    body: "We invest in long-term relationships, acting as an extension of your team rather than a vendor.",
  },
  {
    title: "Excellence",
    body: "We hold a high bar for the talent we present and the service we deliver on every engagement.",
  },
];
---

<BaseLayout title="About" description="Learn about Global Edge Enterprise, a people-first recruitment and staffing firm.">
  <!-- Page header -->
  <section class="bg-navy py-16 text-white">
    <div class="container-px">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-light">About us</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight">People-first recruitment, built on trust</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">
        Global Edge Enterprise is a recruitment and staffing partner dedicated to connecting
        exceptional talent with organizations where they can thrive.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="container-px py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-navy">Our story</h2>
        <p class="mt-4 leading-relaxed text-muted">
          <!-- TODO: replace with the real company story -->
          Global Edge Enterprise, LLC was founded on a simple belief: hiring works best when it is
          built on relationships, not transactions. We bring together recruiters with deep
          experience across industries to help companies find the people who move them forward.
        </p>
        <p class="mt-4 leading-relaxed text-muted">
          Whether you are scaling a team, filling a critical leadership role, or searching for your
          next opportunity, we bring a thoughtful, transparent process to every engagement.
        </p>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-navy">Our mission</h2>
        <p class="mt-4 leading-relaxed text-muted">
          To be the trusted edge that helps organizations and professionals find the right fit —
          delivering quality matches with speed, care, and integrity.
        </p>
        <div class="mt-8 grid grid-cols-2 gap-6">
          {
            stats.map((s) => (
              <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 text-center">
                <div class="text-2xl font-extrabold text-navy">{s.value}</div>
                <div class="mt-1 text-xs text-muted">{s.label}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-slate-50 py-16">
    <div class="container-px">
      <div class="mb-10 text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent-dark">Our values</p>
        <h2 class="mt-3 text-3xl font-bold text-navy">What guides our work</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          values.map((v) => (
            <div class="rounded-xl border border-slate-200 bg-white p-6">
              <h3 class="text-lg font-semibold text-navy">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="container-px py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        differentiators.map((d) => (
          <div class="rounded-xl border border-slate-200 p-6">
            <h3 class="text-base font-semibold text-navy">{d.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{d.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CTA title="Let's work together" secondaryLabel="View careers" secondaryHref="/careers" />
</BaseLayout>
