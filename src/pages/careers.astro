---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

// Google Forms embed = the viewform link with ?embedded=true
const embedUrl = `${site.careersFormUrl}?embedded=true`;
const perks = [
  "Work with recruiters who advocate for you",
  "Access to roles that are never posted publicly",
  "Honest guidance through every step of the process",
  "A partner invested in your long-term career",
];
---

<BaseLayout title="Careers" description="Looking for your next opportunity? Submit your details and our recruiters will be in touch.">
  <!-- Header -->
  <section class="bg-navy py-16 text-white">
    <div class="container-px">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-light">Careers</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight">Find your next opportunity</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">
        Tell us about yourself and the roles you're after. We'll match you with opportunities that
        fit your skills and goals.
      </p>
    </div>
  </section>

  <section class="container-px py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-navy">Why work with us</h2>
        <ul class="mt-6 space-y-4">
          {
            perks.map((p) => (
              <li class="flex gap-3">
                <svg class="mt-0.5 h-5 w-5 flex-none text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-muted">{p}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8 rounded-xl border border-slate-200 bg-slate-50 p-5 text-sm text-muted">
          Prefer email? Send your resume to
          <a href={`mailto:${site.email}`} class="font-medium text-accent-dark hover:underline">{site.email}</a>.
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-navy">Submit your details</h2>
        <p class="mt-2 text-sm text-muted">
          The application form below is powered by Google Forms.
        </p>
        <!-- TODO: replace careersFormUrl in src/data/site.ts with your real Google Form -->
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
          <iframe
            src={embedUrl}
            title="Job application form"
            loading="lazy"
            class="h-[900px] w-full"
          >Loading…</iframe>
        </div>
        <p class="mt-3 text-sm text-muted">
          Form not loading?
          <a href={site.careersFormUrl} target="_blank" rel="noopener" class="font-medium text-accent-dark hover:underline">
            Open it in a new tab
          </a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
